# Copy to config/pipeline.env and edit for your machine.
# The pipeline can also be configured by exporting these variables directly.

# Linux Steam default. Change this if your Steam library is elsewhere.
STEAM_COMMON="$HOME/.local/share/Steam/steamapps/common"

# External checkouts. Set these to wherever you cloned each project.
COHEREX_DIR="$HOME/git/CohereX"
OMNI="$HOME/git/OmniVoice"

# GPU/runtime settings.
GPU_IDS="0"
NUM_GPUS="1"
PAR="8"
BATCH="32"

# auto: train from the reconciled/wiki-filtered dataset without browser review.
# manual: build data/review.html and stop so you can export/apply decisions.
REVIEW_MODE="auto"

# OmniVoice training stages: 0 tokenizes, 1 trains. Leave as-is for full training.
STAGE="0"
STOP_STAGE="1"
